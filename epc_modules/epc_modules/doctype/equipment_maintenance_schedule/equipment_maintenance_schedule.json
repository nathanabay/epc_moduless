{
  "name": "Equipment Maintenance Schedule",
  "doctype": "DocType",
  "module": "EPC Modules",
  "is_submittable": 1,
  "track_changes": 1,
  "fields": [
    {
      "fieldname": "schedule_id",
      "fieldtype": "Data",
      "in_list_view": 1,
      "label": "Schedule ID",
      "read_only": 1
    },
    {
      "fieldname": "equipment",
      "fieldtype": "Link",
      "in_list_view": 1,
      "label": "Equipment",
      "options": "Equipment Register",
      "reqd": 1
    },
    {
      "fieldname": "maintenance_type",
      "fieldtype": "Select",
      "in_list_view": 1,
      "label": "Type",
      "options": "Daily\nWeekly\nMonthly\nQuarterly\nAnnual\nBreakdown",
      "reqd": 1
    },
    {
      "fieldname": "description",
      "fieldtype": "Data",
      "label": "Description",
      "reqd": 1
    },
    {
      "fieldname": "section_break_5",
      "fieldtype": "Section Break",
      "label": "Schedule"
    },
    {
      "fieldname": "interval_days",
      "fieldtype": "Int",
      "label": "Interval (Days)",
      "reqd": 1
    },
    {
      "fieldname": "last_service_date",
      "fieldtype": "Date",
      "label": "Last Service"
    },
    {
      "fieldname": "next_service_date",
      "fieldtype": "Date",
      "label": "Next Service",
      "read_only": 1
    },
    {
      "fieldname": "column_break_8",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "last_service_hours",
      "fieldtype": "Float",
      "label": "Hours at Last Service"
    },
    {
      "fieldname": "next_service_hours",
      "fieldtype": "Float",
      "label": "Hours for Next Service",
      "read_only": 1
    },
    {
      "fieldname": "section_break_11",
      "fieldtype": "Section Break",
      "label": "Alerts"
    },
    {
      "fieldname": "is_scheduled",
      "fieldtype": "Check",
      "label": "In Schedule",
      "default": "1"
    },
    {
      "fieldname": "alerts_enabled",
      "fieldtype": "Check",
      "label": "Send Alerts",
      "default": "1"
    },
    {
      "fieldname": "alert_days_before",
      "fieldtype": "Int",
      "label": "Alert Days Before",
      "default": "7"
    },
    {
      "fieldname": "column_break_14",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "estimated_cost",
      "fieldtype": "Currency",
      "label": "Est. Cost"
    },
    {
      "fieldname": "responsible_vendor",
      "fieldtype": "Link",
      "label": "Service Vendor",
      "options": "Supplier"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1
    },
    {
      "role": "Project Manager",
      "read": 1,
      "write": 1,
      "create": 1
    }
  ]
}