      "fieldtype": "Section Break",
      "label": "Risk Details"
    },
    {
      "fieldname": "triggered_by",
      "fieldtype": "Data",
      "label": "Triggered By"
    },
    {
      "fieldname": "potential_impact",
      "fieldtype": "Text",
      "label": "Potential Impact",
      "reqd": 1
    },
    {
      "fieldname": "section_break_15",
      "fieldtype": "Section Break",
      "label": "Risk Response"
    },
    {
      "fieldname": "mitigation_strategy",
      "fieldtype": "Text",
      "label": "Mitigation Strategy",
      "reqd": 1
    },
    {
      "fieldname": "contingency_plan",
      "fieldtype": "Text",
      "label": "Contingency Plan"
    },
    {
      "fieldname": "column_break_18",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "responsible_person",
      "fieldtype": "Link",
      "label": "Risk Owner",
      "options": "User",
      "reqd": 1
    },
    {
      "fieldname": "review_date",
      "fieldtype": "Date",
      "label": "Review Date",
      "reqd": 1
    },
    {
      "fieldname": "section_break_22",
      "fieldtype": "Section Break",
      "label": "Risk Actions"
    },
    {
      "fieldname": "risk_actions",
      "fieldtype": "Table",
      "label": "Response Actions",
      "options": "Risk Response Action"
    },
    {
      "fieldname": "section_break_26",
      "fieldtype": "Section Break",
      "label": "Status"
