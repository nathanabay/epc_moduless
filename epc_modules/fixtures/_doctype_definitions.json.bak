[
  {
    "name": "Custom BOQ",
    "doctype": "DocType",
    "module": "EPC Modules",
    "autoname": "field:parent_wbs",
    "is_submittable": 1,
    "editable_grid": 1,
    "track_changes": 1,
    "fields": [
      {
        "fieldname": "parent",
        "fieldtype": "Link",
        "in_list_view": 1,
        "label": "Project",
        "options": "Project",
        "reqd": 1
      },
      {
        "fieldname": "parent_wbs",
        "fieldtype": "Link",
        "label": "Parent WBS",
        "options": "WBS Item"
      },
      {
        "fieldname": "item_code",
        "fieldtype": "Link",
        "in_list_view": 1,
        "label": "Item Code",
        "options": "Item",
        "reqd": 1
      },
      {
        "fieldname": "item_name",
        "fieldtype": "Data",
        "label": "Item Name",
        "read_only": 1
      },
      {
        "fieldname": "description",
        "fieldtype": "Small Text",
        "label": "Description"
      },
      {
        "fieldname": "measurement_method",
        "fieldtype": "Select",
        "in_list_view": 1,
        "label": "Measurement Method",
        "options": "Unit-Based\nPercentage-Based\nMilestone-Based",
        "reqd": 1
      },
      {
        "fieldname": "boq_quantity",
        "fieldtype": "Float",
        "in_list_view": 1,
        "label": "BOQ Quantity",
        "reqd": 1
      },
      {
        "fieldname": "uom",
        "fieldtype": "Link",
        "label": "Unit",
        "options": "UOM",
        "reqd": 1
      },
      {
        "fieldname": "unit_rate",
        "fieldtype": "Currency",
        "in_list_view": 1,
        "label": "Unit Rate",
        "reqd": 1
      },
      {
        "fieldname": "total_value",
        "fieldtype": "Currency",
        "in_list_view": 1,
        "label": "Total Value",
        "read_only": 1
      },
      {
        "fieldname": "is_electromechanical",
        "fieldtype": "Check",
        "label": "Electromechanical Item"
      },
      {
        "fieldname": "is_civil",
        "fieldtype": "Check",
        "label": "Civil Item"
      },
      {
        "fieldname": "wbs_code",
        "fieldtype": "Data",
        "label": "WBS Code",
        "read_only": 1
      },
      {
        "fieldname": "column_break_13",
        "fieldtype": "Column Break"
      },
      {
        "fieldname": "billed_quantity",
        "fieldtype": "Float",
        "label": "Billed Quantity",
        "read_only": 1,
        "default": "0"
      },
      {
        "fieldname": "pending_quantity",
        "fieldtype": "Float",
        "label": "Pending Quantity",
        "read_only": 1,
        "formula": "boq_quantity - billed_quantity"
      },
      {
        "fieldname": "column_break_16",
        "fieldtype": "Column Break"
      },
      {
        "fieldname": "status",
        "fieldtype": "Select",
        "in_list_view": 1,
        "label": "Status",
        "options": "Draft\nActive\nCompleted\nCancelled",
        "read_only": 1
      }
    ],
    "permissions": [
      {
        "role": "System Manager",
        "read": 1,
        "write": 1,
        "create": 1,
        "delete": 1,
        "submit": 1
      },
      {
        "role": "Project Manager",
        "read": 1,
        "write": 1,
        "create": 1
      }
    ]
  },
