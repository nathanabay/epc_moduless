    {"fieldname": "severity", "fieldtype": "Select", "label": "Severity", "options": "Fatal\nMajor\nMinor\nNegligible", "in_list_view": 1},
    {"fieldname": "description", "fieldtype": "Text Editor", "label": "Description"},
    {"fieldname": "immediate_action", "fieldtype": "Text Editor", "label": "Immediate Action Taken"},
    {"fieldname": "investigation_section", "fieldtype": "Section Break", "label": "Investigation"},
