    {"fieldname": "incident_date", "fieldtype": "Date", "label": "Incident Date", "reqd": 1, "in_list_view": 1},
    {"fieldname": "incident_time", "fieldtype": "Time", "label": "Incident Time"},
    {"fieldname": "location", "fieldtype": "Data", "label": "Location", "in_list_view": 1},
