{
  "doctype": "DocType",
  "name": "HSE Incident",
  "module": "EPC Modules",
  "autoname": "field:incident_number",
  "is_submittable": 1,
  "editable_grid": 1,
  "fields": [
    {"fieldname": "incident_number", "fieldtype": "Data", "label": "Incident Number", "read_only": 1, "reqd": 1},
