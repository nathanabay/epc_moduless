    {"fieldname": "is_confidential", "fieldtype": "Check", "label": "Confidential"},
    {"fieldname": "media_involvement", "fieldtype": "Check", "label": "Media Involvement"},
    {"fieldname": "regulatory_reporting_required", "fieldtype": "Check", "label": "Regulatory Reporting Required"},
    {"fieldname": "remarks", "fieldtype": "Small Text", "label": "Remarks"}
