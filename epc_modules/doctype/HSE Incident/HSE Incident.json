    {"fieldname": "investigation_date", "fieldtype": "Date", "label": "Investigation Date"},
    {"fieldname": "root_cause", "fieldtype": "Text Editor", "label": "Root Cause"},
    {"fieldname": "corrective_action", "fieldtype": "Text Editor", "label": "Corrective Action"},
    {"fieldname": "preventive_action", "fieldtype": "Text Editor", "label": "Preventive Action"},
    {"fieldname": "impact_section", "fieldtype": "Section Break", "label": "Impact Assessment"},
    {"fieldname": "days_lost", "fieldtype": "Int", "label": "Days Lost"},
    {"fieldname": "cost_impact", "fieldtype": "Currency", "label": "Cost Impact (ETB)"},
    {"fieldname": "reported_by", "fieldtype": "Link", "label": "Reported By", "options": "User"},
