{
  "name": "Equipment Register",
  "doctype": "DocType",
  "module": "EPC Modules",
  "is_submittable": 1,
  "track_changes": 1,
  "fields": [
    {
      "fieldname": "equipment_id",
      "fieldtype": "Data",
      "in_list_view": 1,
      "label": "Equipment ID",
      "read_only": 1
    },
    {
      "fieldname": "equipment_name",
      "fieldtype": "Data",
      "in_list_view": 1,
      "label": "Equipment Name",
      "reqd": 1
    },
    {
      "fieldname": "equipment_category",
      "fieldtype": "Select",
      "in_list_view": 1,
      "label": "Category",
      "options": "Earthmoving\nLifting\nConcrete\nTransport\nPower\nTools",
      "reqd": 1
    },
    {
      "fieldname": "manufacturer",
      "fieldtype": "Data",
      "label": "Manufacturer"
    },
    {
      "fieldname": "model_number",
      "fieldtype": "Data",
      "label": "Model"
    },
    {
      "fieldname": "serial_number",
      "fieldtype": "Data",
      "label": "Serial/VIN"
    },
    {
      "fieldname": "column_break_6",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "year_of_manufacture",
      "fieldtype": "Int",
      "label": "Year of Manufacture"
    },
    {
      "fieldname": "project",
      "fieldtype": "Link",
      "label": "Current Project",
      "options": "Project"
    },
    {
      "fieldname": "equipment_status",
      "fieldtype": "Select",
      "in_list_view": 1,
      "label": "Status",
      "options": "Available\nIn Use\nUnder Maintenance\nUnder Repair\nScrapped\nSold",
      "default": "Available"
