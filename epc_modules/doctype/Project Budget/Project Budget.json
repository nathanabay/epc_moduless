{
  "name": "Project Budget",
  "doctype": "DocType",
  "module": "EPC Modules",
  "autoname": "field:budget_code",
  "is_submittable": 1,
  "track_changes": 1,
  "fields": [
    {
      "fieldname": "budget_code",
      "fieldtype": "Data",
      "label": "Budget Code",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "project",
      "fieldtype": "Link",
      "label": "Project",
      "options": "Project",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "budget_type",
      "fieldtype": "Select",
      "label": "Type",
      "options": "Original\nRevised",
      "default": "Original",
      "in_list_view": 1
    },
    {
      "fieldname": "budget_date",
      "fieldtype": "Date",
      "label": "Budget Date",
      "default": "Today"
    },
    {
      "fieldname": "lines_section",
      "fieldtype": "Section Break",
      "label": "Cost Breakdown"
    },
    {
      "fieldname": "lines",
      "fieldtype": "Table",
      "options": "Budget Line",
      "label": "Budget Lines"
    },
    {
      "fieldname": "total_planned_cost",
      "fieldtype": "Currency",
      "label": "Total Planned Cost",
      "read_only": 1
    },
    {
      "fieldname": "total_actual_cost",
      "fieldtype": "Currency",
      "label": "Total Actual Cost",
      "read_only": 1
    },
    {
      "fieldname": "total_variance",
      "fieldtype": "Currency",
      "label": "Total Variance",
      "read_only": 1
    },
    {
      "fieldname": "variance_percentage",
      "fieldtype": "Float",
      "label": "Variance %",
      "read_only": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Draft\nApproved\nIn Review\nClosed",
      "default": "Draft",
      "in_list_view": 1
    },
    {
      "fieldname": "remarks",
      "fieldtype": "Small Text",
      "label": "Remarks"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1
    },
    {
      "role": "Finance Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1
    },
    {
      "role": "Project Manager",
      "read": 1
    }
  ]
}