{
  "doctype": "DocType",
  "name": "Job Type",
  "module": "EPC Modules",
  "autoname": "field:job_type",
  "fields": [
    { "fieldname": "job_type", "fieldtype": "Data", "label": "Job Type", "reqd": 1, "unique": 1 },
    { "fieldname": "job_category", "fieldtype": "Select", "label": "Category",
      "options": "Labor\nEquipment\nMaterial\nProfessional Services\nOther", "reqd": 1 },
    { "fieldname": "description", "fieldtype": "Text", "label": "Description" },
    { "fieldname": "default_rate", "fieldtype": "Currency", "label": "Default Rate" },
    { "fieldname": "uom", "fieldtype": "Link", "options": "UOM", "label": "UOM", "default": "Hour" },
    { "fieldname": "is_active", "fieldtype": "Check", "label": "Active", "default": 1 },
    { "fieldname": "sort_order", "fieldtype": "Int", "label": "Sort Order", "default": 0 },
    { "fieldname": "breakdown_rates", "fieldtype": "Table", "options": "Job Type Breakdown Rate", "label": "Breakdown Rates by Typology" }
  ],
  "permissions": [
    { "role": "System Manager", "read": 1, "write": 1, "create": 1 },
    { "role": "Projects User", "read": 1 }
  ]
}