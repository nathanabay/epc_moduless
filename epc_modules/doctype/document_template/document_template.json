{
 "doctype": "DocType",
 "name": "Document Template",
 "module": "EPC Modules",
 "autoname": "field:template_name",
 "fields": [
  {"fieldname": "template_name", "fieldtype": "Data", "label": "Template Name", "reqd": 1},
  {"fieldname": "doc_type", "fieldtype": "Select", "label": "Document Type", "options": "Letter\nCertificate\nReport\nMemo\nNotice\nOthers", "reqd": 1, "in_list_view": 1},
  {"fieldname": "description", "fieldtype": "Small Text", "label": "Description"},
  {"fieldname": "content", "fieldtype": "Text Editor", "label": "Template Content"},
  {"fieldname": "placeholders", "fieldtype": "Text", "label": "Available Placeholders", "read_only": 1},
  {"fieldname": "is_active", "fieldtype": "Check", "label": "Is Active", "default": 1}
 ],
 "permissions": [
  {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
  {"role": "Project Manager", "read": 1, "write": 1, "create": 1}
 ]
}
