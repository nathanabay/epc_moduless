{
  "name": "Work Package",
  "doctype": "DocType",
  "module": "EPC Modules",
  "is_submittable": 1,
  "autoname": "hash",
  "track_changes": 1,
  "fields": [
    {
      "fieldname": "package_number",
      "fieldtype": "Data",
      "label": "Package Number",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "project",
      "fieldtype": "Link",
      "label": "Project",
      "options": "Project",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "package_name",
      "fieldtype": "Data",
      "label": "Package Name",
      "reqd": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Draft\nPlanned\nIn Progress\nOn Hold\nCompleted\nCancelled",
      "default": "Draft",
      "in_list_view": 1
    },
    {
      "fieldname": "package_type",
      "fieldtype": "Select",
      "label": "Package Type",
      "options": "Civil\nMechanical\nElectrical\nPlumbing\nHVAC\n instrumentation\nCommissioning\nOther",
      "default": "Civil"
    },
    {
      "fieldname": "priority",
      "fieldtype": "Select",
      "label": "Priority",
      "options": "Low\nMedium\nHigh\nCritical",
      "default": "Medium"
    },
    {
      "fieldname": "section_details",
      "fieldtype": "Section Break",
      "label": "Package Details"
    },
    {
      "fieldname": "wbs_item",
      "fieldtype": "Link",
      "label": "WBS Item",
      "options": "WBS Item"
    },
    {
      "fieldname": "location",
      "fieldtype": "Data",
      "label": "Location"
    },
    {
      "fieldname": "scope_of_work",
      "fieldtype": "Text Editor",
      "label": "Scope of Work"
    },
    {
      "fieldname": "column_break_schedule",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "planned_start",
      "fieldtype": "Date",
      "label": "Planned Start"
    },
    {
      "fieldname": "planned_end",
      "fieldtype": "Date",
      "label": "Planned End"
    },
    {
      "fieldname": "actual_start",
      "fieldtype": "Date",
      "label": "Actual Start"
    },
    {
      "fieldname": "actual_end",
      "fieldtype": "Date",
      "label": "Actual End"
    },
    {
      "fieldname": "section_resources",
      "fieldtype": "Section Break",
      "label": "Resources"
    },
    {
      "fieldname": "assigned_to",
      "fieldtype": "Link",
      "label": "Assigned To",
      "options": "User"
    },
    {
      "fieldname": "contractor",
      "fieldtype": "Data",
      "label": "Contractor/Team"
    },
    {
      "fieldname": "column_break_cost",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "estimated_hours",
      "fieldtype": "Float",
      "label": "Estimated Hours"
    },
    {
      "fieldname": "actual_hours",
      "fieldtype": "Float",
      "label": "Actual Hours"
    },
    {
      "fieldname": "budget_cost",
      "fieldtype": "Currency",
      "label": "Budget Cost"
    },
    {
      "fieldname": "section_tasks",
      "fieldtype": "Section Break",
      "label": "Tasks"
    },
    {
      "fieldname": "tasks",
      "fieldtype": "Table",
      "options": "Work Package Task",
      "label": "Tasks"
    },
    {
      "fieldname": "section_quality",
      "fieldtype": "Section Break",
      "label": "Quality & Safety"
    },
    {
      "fieldname": "safety_checklist",
      "fieldtype": "Small Text",
      "label": "Safety Checklist"
    },
    {
      "fieldname": "column_break_itp",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "itp_required",
      "fieldtype": "Check",
      "label": "ITP Required",
      "default": "0"
    },
    {
      "fieldname": "itp_reference",
      "fieldtype": "Data",
      "label": "ITP Reference"
    },
    {
      "fieldname": "remarks",
      "fieldtype": "Small Text",
      "label": "Remarks"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Project Manager",
      "read": 1,
      "write": 1,
      "create": 1
    },
    {
      "role": "Site Supervisor",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1
    }
  ]
}